# Base de données
# DEV (local) : PostgreSQL Docker - lancer "docker compose up -d"
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/artisan_btp?schema=public"
# PROD (Vercel + Neon) : ajouter connect_timeout=30 pour éviter les timeouts au cold start
# Ex: postgresql://user:pass@host/db?sslmode=require&pgbouncer=true&connect_timeout=30

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="votre-secret-nextauth-genere-avec-openssl"

# Resend (emails)
RESEND_API_KEY="re_xxx"

# OpenAI (estimateur IA)
OPENAI_API_KEY="sk-xxx"
