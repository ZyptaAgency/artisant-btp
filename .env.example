# Base de données
# DEV (local) : PostgreSQL Docker - lancer "docker compose up -d"
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/artisan_btp?schema=public"
# PROD (Vercel + Neon) : URL pooled + pgbouncer + connect_timeout
# NE PAS utiliser channel_binding=require (peut causer ERR_HTTP2_PROTOCOL_ERROR)
# Ex: postgresql://user:pass@host-pooler.region.aws.neon.tech/db?sslmode=require&pgbouncer=true&connect_timeout=30

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="votre-secret-nextauth-genere-avec-openssl"

# Resend (emails - mot de passe oublié, etc.)
# 1. Créer un compte sur resend.com
# 2. API Keys → Create API Key
# 3. Copier la clé (re_xxx)
RESEND_API_KEY="re_xxx"
# EMAIL_FROM (optionnel). Par défaut: onboarding@resend.dev (tests)
# Une fois zypta.be vérifié dans Resend: EMAIL_FROM="Zypta BTP <noreply@zypta.be>"

# OpenAI (estimateur IA)
OPENAI_API_KEY="sk-xxx"
